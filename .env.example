# ============================================
# ANURA CONNECT CHAT AGENT - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# --- Email Notifications (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@anuraconnect.com
SMTP_PASS=your-app-password-here
SMTP_FROM=chatbot@anuraconnect.com

# --- Bullhorn CRM ---
BULLHORN_CLIENT_ID=your-bullhorn-client-id
BULLHORN_CLIENT_SECRET=your-bullhorn-client-secret
BULLHORN_USERNAME=your-bullhorn-username
BULLHORN_PASSWORD=your-bullhorn-password

# --- Server ---
PORT=3001
